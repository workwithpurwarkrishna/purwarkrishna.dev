<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{% if metaTitle %}{{ metaTitle }}{% else %}{{ title }} — Krishna Purwar{% endif %}</title>
<meta name="description" content="{{ description }}" />
<link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/icons/png/favicon-32.png" sizes="32x32" type="image/png" />
<link rel="icon" href="/icons/png/favicon-16.png" sizes="16x16" type="image/png" />
<link rel="apple-touch-icon" href="/icons/app/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#16130f" id="themeColorMeta" />

<!-- Set theme before paint — no flash. Brand is dark-first; respects saved choice. -->
<script>
  (function () {
    try {
      var saved = localStorage.getItem("pk-theme");
      document.documentElement.setAttribute("data-theme", saved || "dark");
    } catch (e) {}
  })();
</script>

<!-- Google Analytics -->
